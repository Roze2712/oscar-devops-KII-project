# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional: comma-separated emails allowed to open /admin (same as Supabase Auth email).
# If unset, any logged-in user can access /admin.
# ADMIN_EMAILS=you@example.com

# Resend — order emails via app/api/send-order (https://resend.com/api-keys)
# Sender and notification inbox are set in route.ts (free tier: onboarding@resend.dev).
RESEND_API_KEY=re_xxxxxxxx
